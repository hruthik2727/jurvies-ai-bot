# Jurvies AI Bot — Environment Variables
# Copy this file to .env and fill in your values

# === REQUIRED ===
GOOGLE_API_KEY=your_google_api_key_here

# === OPTIONAL ===
MODEL=gemini-2.5-flash
MAX_TOKENS=1024
TEMPERATURE=0.7
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
SYSTEM_PROMPT=You are Jurvies, a friendly and helpful AI assistant. You are knowledgeable, concise, and always polite.
